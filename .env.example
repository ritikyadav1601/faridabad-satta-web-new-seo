# Separate MongoDB source for the 12 promoted Top Games on the homepage.
# The collection should contain one document per game/date, e.g.
# { game: "DESHAWER", resultDate: "2026-07-15", result: "73" }
TOP_GAMES_MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/top-games?retryWrites=true&w=majority
TOP_GAMES_MONGODB_DB=top-games
TOP_GAMES_MONGODB_COLLECTION=dailynumbers
